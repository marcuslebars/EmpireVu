# EmpireVu environment variables.
# Copy to .env.local for local development. NEVER commit real values.

# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Bypasses RLS — used solely by the sanctioned service-role paths
# (lead intake, public booking, Telnyx voice routes).
SUPABASE_SERVICE_ROLE_KEY=

# ─── App ─────────────────────────────────────────────────────────────────────
# Public base URL, e.g. https://empirevu.com. Used to build self-booking links.
# Must be set on BOTH the web and worker services.
APP_BASE_URL=
# Defaults to America/Toronto when unset.
BUSINESS_TIMEZONE=

# ─── Lead intake ─────────────────────────────────────────────────────────────
# Organization slug that inbound leads are pinned to (default: a1-group).
LEAD_INTAKE_ORG_SLUG=

# ─── Telnyx Voice AI Assistant ───────────────────────────────────────────────
# See docs/telnyx-integration.md for the endpoint URLs and portal setup.
#
# Shared secret Telnyx must send as the `x-empirevu-telnyx-secret` header on all
# four endpoints. Requests without an exact match are rejected with 401.
TELNYX_WEBHOOK_SECRET=
# Company (brand) UUID used when the dialled number isn't mapped in
# `telnyx_numbers`. Without it, an unmapped number resolves to no tenant.
TELNYX_DEFAULT_TENANT_ID=
# `true` logs full raw request payloads so field names can be confirmed on first
# deploy. Turn OFF afterwards — payloads contain caller PII.
TELNYX_DEBUG_PAYLOADS=false
# Booking deposit. A BUSINESS RULE, not pricing-engine output — the engine has no
# deposit concept. Flat cents (default 10000 = $100); TELNYX_DEPOSIT_PERCENT wins
# if both are set.
TELNYX_DEPOSIT_CENTS=10000
TELNYX_DEPOSIT_PERCENT=

# ─── AI ──────────────────────────────────────────────────────────────────────
# Required on BOTH web and worker (the ai_analyze workflow action runs on the worker).
ANTHROPIC_API_KEY=

# ─── Voice (Cartesia / "Marina") ─────────────────────────────────────────────
# All three required. Needed on BOTH web (manual + quick call) and worker
# (the call_lead workflow action). CARTESIA_FROM_NUMBER_ID is the phone number's
# ID from your Cartesia account — not the phone number itself.
CARTESIA_API_KEY=
CARTESIA_AGENT_ID=
CARTESIA_FROM_NUMBER_ID=

# ─── Outbound email (Resend) ─────────────────────────────────────────────────
RESEND_API_KEY=
# Customer-facing sender for AI-drafted replies.
OUTBOUND_FROM_EMAIL=
OUTBOUND_REPLY_TO=
# Internal lead-notification sender/recipients.
LEAD_FROM_EMAIL=
LEAD_NOTIFY_EMAIL=
OWNER_EMAIL=

# ─── Outbound SMS (Twilio) ───────────────────────────────────────────────────
# All-or-nothing: SMS is disabled unless all three are set.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ─── Worker ──────────────────────────────────────────────────────────────────
# Optional identifier for the workflow-event worker instance.
WORKFLOW_EVENT_WORKER_ID=
